{
  "name": "learnerapp",
  "version": "0.1.0",
  "description": "Learner desktop app",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "electron:dev": "concurrently -k -s first -n NEXT,ELECTRON -c blue,green \"next dev -p 3000\" \"wait-on http://localhost:3000 && cross-env NEXT_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "electron:preview": "npm run build && electron .",
    "electron:dist": "npm run build && electron-builder",
    "build": "cross-env NEXT_OUTPUT_EXPORT=1 next build",
    "start": "serve out",
    "lint": "eslint",
    "test:mastery": "node scripts/masteryCardsSmoke.js"
  },
  "build": {
    "appId": "com.learner.app",
    "productName": "Learner",
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Learner uses the microphone to dictate mastery answers."
      }
    }
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@langchain/core": "^1.2.1",
    "@langchain/openai": "^1.5.3",
    "@phosphor-icons/react": "^2.1.10",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-mathematics": "^3.27.1",
    "@tiptap/markdown": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@xyflow/react": "^12.11.2",
    "embla-carousel-react": "^8.6.0",
    "katex": "^0.16.47",
    "langchain": "^1.5.2",
    "lowlight": "^3.3.0",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "serve": "^14.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
